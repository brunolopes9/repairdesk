# Copia este ficheiro para .env e ajusta antes de produção.
# Em dev/local não é obrigatório — o docker-compose tem defaults.

DB_SA_PASSWORD=Repair!Desk2026

# Em produção, gera uma chave nova com >= 32 chars: openssl rand -base64 48
JWT_SIGNING_KEY=dev-only-replace-this-key-at-least-32-chars-long-please-please-please
JWT_ISSUER=repairdesk-local
JWT_AUDIENCE=repairdesk-local

Push__Enabled=true
Push__VapidPublicKey=
Push__VapidPrivateKey=
Push__Subject=mailto:suporte@repairdesk.pt
Push__TtlSeconds=86400
Push__DeliveredRetentionDays=30

SEED_ADMIN_EMAIL=bruno.miguel.martins.lopes@gmail.com
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_DISPLAY_NAME=Bruno Lopes

# Storage de fotos. Default local; muda para r2 quando tiveres Cloudflare R2 configurado.
Storage__Provider=local
Storage__LocalRoot=/data/photos
Storage__R2__AccountId=
Storage__R2__AccessKey=
Storage__R2__Secret=
Storage__R2__Bucket=

# Backups automáticos. Em dev fica desligado; em produção usar Backup__Enabled=true.
Backup__Enabled=false
Backup__CronSchedule=03:00
Backup__RetentionDays=30
Backup__LocalPath=/backups
Backup__DatabaseName=RepairDesk
Backup__R2__Bucket=
Backup__R2__Prefix=backups

# AT NIF lookup. Em dev fica off — o webservice exige certificado real da AT.
# O serviço degrada graciosamente: throw AtNifUnavailableException se cert não configurado.
# Em produção, coloca o .cer e .pem em /opt/repairdesk/secrets/at/ e activa AT_PRODUCTION=true.
AT_PRODUCTION=false
AT_SECRETS_HOST_PATH=./secrets/at
AT_CERT_PATH=
AT_KEY_PATH=
AT_KEY_PASSWORD=
AT_NIF_MAX_DAILY_CALLS=100

# Sprint 147+150: storage de faturas fornecedor + n8n IMAP automation.
# Para sync automático com Drive/Dropbox: SUPPLIER_INVOICES_HOST_PATH=~/Dropbox/RepairDesk/faturas
SUPPLIER_INVOICES_HOST_PATH=./data/supplier-invoices

# n8n (profile automation, opt-in via `docker compose --profile automation up -d`)
N8N_BASIC_AUTH_USER=bruno
N8N_BASIC_AUTH_PASSWORD=changeme-please
# Gera uma key forte: openssl rand -base64 32. MUDAR ANTES DE PRODUÇÃO.
N8N_ENCRYPTION_KEY=dev-only-change-me-32-chars-please
