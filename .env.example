# Copia este ficheiro para .env e ajusta antes de produção.
# Em dev/local não é obrigatório — o docker-compose tem defaults.

DB_SA_PASSWORD=Repair!Desk2026

# Em produção, gera uma chave nova com >= 32 chars: openssl rand -base64 48
JWT_SIGNING_KEY=dev-only-replace-this-key-at-least-32-chars-long-please-please-please
JWT_ISSUER=repairdesk-local
JWT_AUDIENCE=repairdesk-local

SEED_ADMIN_EMAIL=bruno.miguel.martins.lopes@gmail.com
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_DISPLAY_NAME=Bruno Lopes

# Storage de fotos. Default local; muda para r2 quando tiveres Cloudflare R2 configurado.
Storage__Provider=local
Storage__LocalRoot=/data/photos
Storage__R2__AccountId=
Storage__R2__AccessKey=
Storage__R2__Secret=
Storage__R2__Bucket=
