# Copy this file to .env.production on the server.
# Never commit the real .env.production file.

REGISTRY=ghcr.io
IMAGE_NAMESPACE=brunolopes9/repairdesk
IMAGE_TAG=v0.1.0

WEB_HTTP_PORT=127.0.0.1:8088

MSSQL_PID=Express
DB_NAME=RepairDesk
DB_SA_PASSWORD=replace-with-strong-sql-password
REDIS_PASSWORD=replace-with-strong-redis-password

JWT_ISSUER=https://api.repairdesk.pt
JWT_AUDIENCE=https://app.repairdesk.pt
JWT_SIGNING_KEY=replace-with-openssl-rand-base64-48

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-first-admin-password
SEED_ADMIN_DISPLAY_NAME=RepairDesk Admin

# Photo storage. Use local by default; switch to r2 after creating the R2 bucket/token.
Storage__Provider=local
Storage__LocalRoot=/data/photos
Storage__R2__AccountId=
Storage__R2__AccessKey=
Storage__R2__Secret=
Storage__R2__Bucket=

# Automatic DB backups. Reuses Storage__R2__AccountId/AccessKey/Secret by default.
Backup__Enabled=true
Backup__CronSchedule=03:00
Backup__RetentionDays=30
Backup__LocalPath=/backups
Backup__DatabaseName=RepairDesk
Backup__R2__Bucket=repairdesk-prod-backups
Backup__R2__Prefix=backups

# AT NIF lookup. Store files on the server, never in git.
AT_PRODUCTION=true
AT_SECRETS_HOST_PATH=/opt/repairdesk/secrets/at
AT_CERT_PATH=/run/secrets/at/ChaveCifraPublicaAT2027.cer
AT_KEY_PATH=/run/secrets/at/at-private-key.pem
AT_KEY_PASSWORD=replace-with-key-password-if-encrypted
AT_NIF_MAX_DAILY_CALLS=100

# Optional Prometheus-style metrics endpoint.
# Keep disabled unless protected by localhost/IP allowlist or Basic Auth.
Metrics__Enabled=false
Metrics__AllowedIps__0=127.0.0.1
Metrics__BasicAuthUsername=
Metrics__BasicAuthPassword=
