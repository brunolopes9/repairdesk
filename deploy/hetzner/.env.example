# Sprint 251 setup template (Doc 78). Copia para `.env` e preenche com valores
# do 1Password vault "Mender Production". Permissões finais: chmod 600 .env
#
# NUNCA committar este ficheiro preenchido — .gitignore já protege.

# ===== Versão da imagem =====
IMAGE_NAMESPACE=brunolopes9/repairdesk
IMAGE_TAG=v0.1.0
WEB_HTTP_PORT=127.0.0.1:8088
DB_NAME=RepairDesk

# ===== Database (gerar 1Password — evitar $@! para não partir shell) =====
DB_SA_PASSWORD=

# ===== Redis (gerar 1Password) =====
REDIS_PASSWORD=

# ===== JWT (openssl rand -base64 48 | head -c 64) =====
JWT_ISSUER=mender-prod
JWT_AUDIENCE=mender-prod
JWT_SIGNING_KEY=

# ===== Seed admin (vais ser forçado a mudar no primeiro login) =====
SEED_ADMIN_EMAIL=bruno.miguel.martins.lopes@gmail.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_DISPLAY_NAME=Bruno Lopes

# ===== Storage R2 (Cloudflare) =====
Storage__Provider=r2
Storage__LocalRoot=/data/photos
Storage__R2__AccountId=
Storage__R2__AccessKey=
Storage__R2__Secret=
Storage__R2__Bucket=mender-prod-photos

# ===== Backup SQL para R2 =====
Backup__Enabled=true
Backup__CronSchedule=03:00
Backup__RetentionDays=30
Backup__LocalPath=/backups
Backup__DatabaseName=RepairDesk
Backup__R2__Bucket=mender-prod-backups
Backup__R2__Prefix=sql

# ===== DP keys backup (Sprint 352 — Doc 76 gap crítico) =====
# Gera password 32+ chars; guarda em 1Password. SE PERDERES, todos os
# secrets cifrados em DB ficam irrecuperáveis. NUNCA mudar depois.
DPKEYS_BACKUP_ENABLED=true
DPKEYS_BACKUP_KEYS_PATH=/data/dp-keys
DPKEYS_BACKUP_CRON=03:30
DPKEYS_BACKUP_PASSWORD=
DPKEYS_BACKUP_R2_BUCKET=mender-prod-backups
DPKEYS_BACKUP_R2_PREFIX=

# ===== Sentry (Sprint 250) — criar projecto sentry.io =====
SENTRY_DSN=

# ===== CORS apertado (Sprint 249) =====
CORS_ORIGIN_PRIMARY=https://app.mender.pt
FRONTEND_BASE_URL=https://app.mender.pt

# ===== Anthropic LLM (per-tenant via UI, mas key central opcional) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== AT NIF lookup (cert + key em /opt/repairdesk/secrets/at) =====
AT_PRODUCTION=true
AT_CERT_PATH=/run/secrets/at/cert.pem
AT_KEY_PATH=/run/secrets/at/private.key
AT_KEY_PASSWORD=
AT_NIF_MAX_DAILY_CALLS=100
AT_SECRETS_HOST_PATH=/opt/repairdesk/secrets/at

# ===== Metrics (opcional — basic auth para Prometheus scrape) =====
Metrics__Enabled=false
Metrics__AllowedIps__0=127.0.0.1
Metrics__BasicAuthUsername=
Metrics__BasicAuthPassword=

# ===== E2E (SEMPRE false em prod — Doc 74) =====
# E2E__Enabled=false (default no appsettings.json — não definir aqui)
